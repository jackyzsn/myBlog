---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const postCount = sortedPosts.length;
const allTags = new Set<string>();
sortedPosts.forEach(p => p.data.tags.forEach(t => allTags.add(t)));
const tagCount = allTags.size;
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "hero-glow relative pt-10 pb-8",
        "border-b border-border",
      ]}
    >
      <p class="mb-2 text-sm tracking-widest text-accent uppercase">
        <span class="prompt-cursor">~ /{SITE.author.toLowerCase().replace(/\s+/g, "-")} $ whoami</span>
      </p>

      <h1 class="my-2 inline-block text-4xl font-bold sm:my-4 sm:text-5xl">
        {SITE.title}
      </h1>

      <a
        target="_blank"
        href="/rss.xml"
        class="ms-2 inline-block align-middle"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="inline-block scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p class="mt-3 text-base">
        Notes on full-stack engineering, debugging adventures, and the occasional puzzle —
        collected over the years by a developer who likes to write things down.
      </p>

      <blockquote class="hero-quote mt-5 text-sm sm:text-base">
        And a new philosophy emerged called quantum physics, which suggests that the
        individual's function is to inform and be informed. You really exist only when
        you're in a field sharing and exchanging information. You create the realities
        you inhabit.
      </blockquote>

      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        <span class="rounded-full border border-border px-3 py-1">
          <span class="font-semibold text-accent">{postCount}</span> posts
        </span>
        <span class="rounded-full border border-border px-3 py-1">
          <span class="font-semibold text-accent">{tagCount}</span> tags
        </span>
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/archives/"
        >
          Browse archives
        </LinkButton>
      </div>

      {
        SOCIALS.length > 0 && (
          <div class="mt-5 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Find me:</div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
